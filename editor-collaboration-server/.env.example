# Port for the Express + Hocuspocus server
PORT=1234

# Webhook URL to communicate with Laravel backend
WEBHOOK_URL=http://127.0.0.1:8000/api/collaboration

# Path to the local whisper.cpp installation (optional, for audio dictation)
WHISPER_PATH=/opt/homebrew/var/www/whisper.cpp

# Path to the local llama.cpp installation (optional, for AI grammar correction)
LLAMA_PATH=/opt/homebrew/var/www/llama.cpp
