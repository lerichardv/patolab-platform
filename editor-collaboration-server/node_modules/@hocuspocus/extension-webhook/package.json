{
	"name": "@hocuspocus/extension-webhook",
	"version": "4.1.0",
	"description": "hocuspocus webhook extension",
	"homepage": "https://hocuspocus.dev",
	"keywords": [
		"hocuspocus",
		"webhook",
		"api",
		"rest",
		"yjs"
	],
	"license": "MIT",
	"type": "module",
	"main": "dist/hocuspocus-webhook.cjs",
	"module": "dist/hocuspocus-webhook.esm.js",
	"types": "dist/index.d.ts",
	"exports": {
		"source": {
			"import": "./src/index.ts"
		},
		"default": {
			"import": "./dist/hocuspocus-webhook.esm.js",
			"require": "./dist/hocuspocus-webhook.cjs",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"src",
		"dist"
	],
	"dependencies": {
		"@hocuspocus/common": "^4.1.0",
		"@hocuspocus/server": "^4.1.0",
		"@hocuspocus/transformer": "^4.1.0"
	},
	"peerDependencies": {
		"yjs": "^13.6.8"
	},
	"gitHead": "702ec724b099264467c7fafa854a3988c7314ff9",
	"repository": {
		"url": "https://github.com/ueberdosis/hocuspocus"
	},
	"publishConfig": {
		"access": "public"
	}
}
